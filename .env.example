# Firebase web configuration.
#
# These values are NOT secrets. Firebase deliberately publishes them: they are
# compiled into the JavaScript bundle that every visitor downloads, and can be
# read from the browser's network tab on any deployed Firebase app.
#
# What actually protects the data is the security rules in `firestore.rules`
# and `database.rules.json`, which run on Google's servers and cannot be
# bypassed by a modified client. Treat those files as the security boundary -
# not the confidentiality of the values below.
#
# Copy this file to `.env` and fill in the values from:
#   Firebase console -> Project settings -> General -> Your apps -> SDK setup
#
# `.env` is gitignored. Never commit real project values, not because they are
# secret, but because a public repository should not point strangers at a
# personal Firebase project's quota and billing.

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# Optional. Only needed if analytics is enabled.
VITE_FIREBASE_MEASUREMENT_ID=

# Optional. Only needed when the Realtime Database instance is not the default
# (`https://<project-id>-default-rtdb.firebaseio.com`), e.g. a regional
# instance such as `https://<project-id>-default-rtdb.europe-west1.firebasedatabase.app`.
# Live bus tracking degrades gracefully if this is wrong or absent.
VITE_FIREBASE_DATABASE_URL=
